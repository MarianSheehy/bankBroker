<form action="/report" method="POST">
  <div class="field">
    <label class="label">Enter Amount</label>
    <input class="input" type="number" placeholder="Euros" name="amount" value="1" />
  </div>
  <div>
    <div class="box field is-horizontal">
      <div class="field-body ml-6">
        <div class="control is-expanded mt-2">
          <label class="radio">
            <input type="radio" name="method" value="paypal" /> Paypal
          </label>
          <label class="radio">
            <input type="radio" name="method" value="cash" /> Cash
          </label>
        </div>
      </div>
      <div class="field-body">
        <div class="select">
          <select name="bank">
            {{#each banks}}
              <option value="{{_id}}">{{lastName}}, {{firstName}}</option>
            {{/each}}
          </select>
        </div>
      </div>
    </div>
  </div>
  <div class="field">
    <div class="control">
      <button class="button is-success is-fullwidth">Submit Selection</button>
    </div>
  </div>
</form>
