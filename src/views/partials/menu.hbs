<nav class="navbar">
  <a role="button" class="navbar-burger" data-target="navMenu" aria-label="menu" aria-expanded="false">
  </a>
  <div class="navbar-menu" id="navMenu">
    <div class="navbar-end">
      <div class="navbar-item">
        <div class="buttons">
          <a id="dashboard" class="button has-background-success-dark has-text-white" href="/dashboard">Link Banks</a>
          <a id="banks" class="button has-background-success-dark has-text-white" href="/banks">My Banks</a>
          <a id="transactions" class="button has-background-success-dark has-text-white" href="/transactions">All Transactions</a>
          <a id="reports" class="button has-background-success-dark has-text-white" href="/reports">Reports</a>
          <a id="account" class="button has-background-success-dark has-text-white" href="/user">My Account</a>
