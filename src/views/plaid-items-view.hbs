{{> menu active=active}}

<section class="section">
  <div class="has-text-centered">
    <h1 class="title is-2 has-text-weight-bold">
      Linked bank items
    </h1>

    <p class="mb-4">
      <span
        class="is-inline-block"
        style="width: 96px; height: 4px; background-color: #ffdd57; border-radius: 999px;"
      ></span>
    </p>

    <h2 class="subtitle is-5 has-text-grey-dark">
      Historic details of your bank connections
      <br>
      <br>
    </h2>
  </div>

  {{#if items.length}}
    <table class="table is-fullwidth is-striped">
      <thead>
        <tr>
          <th>Bank Name</th>
          <th>Created</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        {{#each items}}
          <tr>
            <td>{{this.institutionName}}</td>
            <td>{{this.createdAt}}</td>
            <td>
              <a class="button is-small" href="/transactions?itemId={{this.itemId}}">
                View transactions
              </a>
            </td>
          </tr>
        {{/each}}
      </tbody>
    </table>
  {{else}}
    <p>No bank items linked yet.</p>
  {{/if}}
</section>

<script src="/js/banks-sync.js"></script>