{{> menu active=active}}

<section class="section">
  <h1 class="title">Reports</h1>

  <form method="get" action="/reports" class="box mb-5">
    <div class="field is-horizontal">
      <div class="field-body">

        <div class="field">
          <label class="label">Bank</label>
          <div class="control">
            <div class="select is-fullwidth">
              <select name="itemId">
                <option value="all">All banks</option>
                {{#each items}}
                <option value="{{this.itemId}}" {{#ifEquals ../filters.itemId this.itemId}}selected{{/ifEquals}}>
                  {{#if this.institutionName}}{{this.institutionName}}{{else}}Unknown bank{{/if}}
                </option>
                {{/each}}
              </select>
            </div>
          </div>
        </div>

        <div class="field">
          <label class="label">Category</label>
          <div class="control">
            <div class="select is-fullwidth">
              <select name="category">
                <option value="all">All categories</option>
                {{#each categories}}
                <option value="{{this.detailed}}" {{#ifEquals ../filters.category this.detailed}}selected{{/ifEquals}}>
                  {{this.primary}} – {{this.detailed}}
                  {{/each}}
              </select>
            </div>
          </div>
        </div>

        <div class="field">
          <label class="label">Start date</label>
          <div class="control">
            <input class="input" type="date" name="startDate" value="{{filters.startDate}}">
          </div>
        </div>

        <div class="field">
          <label class="label">End date</label>
          <div class="control">
            <input class="input" type="date" name="endDate" value="{{filters.endDate}}">
          </div>
        </div>

        <div class="field">
          <label class="label">Min amount</label>
          <div class="control">
            <input class="input" type="number" step="0.01" name="minAmount" value="{{filters.minAmount}}">
          </div>
        </div>

        <div class="field">
          <label class="label">Max amount</label>
          <div class="control">
            <input class="input" type="number" step="0.01" name="maxAmount" value="{{filters.maxAmount}}">
          </div>
        </div>

      </div>
    </div>

    <div class="field is-grouped">
      <div class="control">
        <button class="button is-link has-background-grey-light has-text-black" type="submit">Apply filters</button>
      </div>
      <div class="control">
        <a class="button is-light" href="/reports">Clear</a>
      </div>
      <a class="button is-link has-background-warning has-text-black"
        href="/reports/export.csv?itemId={{filters.itemId}}&category={{filters.category}}&startDate={{filters.startDate}}&endDate={{filters.endDate}}&minAmount={{filters.minAmount}}&maxAmount={{filters.maxAmount}}">
        Export to CSV
      </a>
    </div>
  </form>

  <div class="content">
    <p><strong>Total amount:</strong> {{toFixed2 total}}</p>
  </div>

  {{#if transactions.length}}
  <table class="table is-fullwidth is-striped">
    <thead>
      <tr>
        <th>Date</th>
        <th>Name</th>
        <th>Category</th>
        <th class="has-text-right">Amount</th>
      </tr>
    </thead>
    <tbody>
      {{#each transactions}}
      <tr>
        <td>{{this.date}}</td>

        <td>
          {{this.merchant_name}}
          {{#unless this.merchant_name}}
          {{this.name}}
          {{/unless}}
        </td>

        <td>
          {{#if this.personalFinanceCategory}}
          <img src="{{this.personalFinanceCategoryIconUrl}}" alt="{{this.personalFinanceCategory.detailed}}"
            style="width:16px;height:16px;vertical-align:middle;margin-right:4px;">
          {{this.personalFinanceCategory.detailed}}
          {{else}}
          Uncategorised
          {{/if}}
        </td>

        <td class="has-text-right">{{this.amount}}</td>
      </tr>
      {{/each}}
    </tbody>
  </table>
  {{else}}
  <p>No transactions match these filters.</p>
  {{/if}}

  <script>
    document.addEventListener("DOMContentLoaded", function () {
      document.querySelectorAll("form.category-form .category-select")
        .forEach(function (selectEl) {
          selectEl.addEventListener("change", function () {
            // submit the parent form when the dropdown changes
            selectEl.form.submit();
          });
        });
    });
  </script>
</section>